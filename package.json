{
  "name": "playwright-excel-reporter",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright Excel Reporter scaffold",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "node scripts/clean.mts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:unit": "playwright test tests/unit",
    "test:integration": "playwright test tests/integration",
    "verify": "npm run lint && npm run typecheck && npm run test",
    "example": "cd examples && npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/better-sqlite3": "^7.4.0",
    "@types/node": "^24.6.0",
    "better-sqlite3": "^12.0.0",
    "eslint": "^9.16.0",
    "prettier": "^3.6.3",
    "tsup": "^8.1.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "vitest": "^4.1.10"
  }
}
