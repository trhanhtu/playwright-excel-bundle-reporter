{
  "name": "playwright-excel-reporter",
  "version": "0.1.0",
  "description": "Playwright Excel Reporter scaffold",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "npm run build",
    "dev": "tsup --watch",
    "clean": "node scripts/clean.mts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit && npm run lint:fix"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/better-sqlite3": "^7.4.0",
    "@types/node": "^24.6.0",
    "better-sqlite3": "^12.0.0",
    "eslint": "^9.16.0",
    "prettier": "^3.6.3",
    "tsup": "^8.1.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "vitest": "^4.1.10",
    "xlsx": "^0.18.5"
  }
}
